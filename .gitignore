# Локальные черновики — не версионируются
_local/
*.local.md

# Оркестратор: лок активного тика
orchestrator/.lock
# Прогоны (локальный аудит, могут содержать произвольный текст → не в публичный remote); каталог сохраняем
orchestrator/_runs/*
!orchestrator/_runs/.gitkeep
# Локальное состояние Дирижёра (idempotency)
orchestrator/_state/
# Сборка Rust-бинарей (бинари не версионируем; Cargo.lock — да)
orchestrator/bin/hq-spawn/target/
orchestrator/bin/hq-conductor/target/

# Сессии: активные и архив (могут содержать пути и PID — не в публичный remote)
orchestrator/sessions/active/*
!orchestrator/sessions/active/.gitkeep
orchestrator/sessions/_archive/*
!orchestrator/sessions/_archive/.gitkeep

# OS
.DS_Store
Thumbs.db
desktop.ini
