{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hq/orchestrator/planner",
  "title": "hq-planner output",
  "description": "Декомпозиция принятой работы на подзадачи + граф зависимостей + волны.",
  "type": "object",
  "additionalProperties": false,
  "required": ["tasks", "waves"],
  "properties": {
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "repo", "scope_paths", "depends_on", "parallel_safe_with", "dod", "priority", "spec_md"],
        "properties": {
          "id": { "type": "string", "pattern": "^TASK-[0-9]{4}$" },
          "repo": { "type": "string", "description": "репо или 'cross'" },
          "scope_paths": {
            "type": "array", "items": { "type": "string" },
            "description": "Объявленная область (файлы/каталоги/модуль). Основа для parallel-safe."
          },
          "depends_on": {
            "type": "array", "items": { "type": "string", "pattern": "^TASK-[0-9]{4}$" },
            "description": "только-после: эти задачи должны быть done раньше."
          },
          "parallel_safe_with": {
            "type": "array", "items": { "type": "string", "pattern": "^TASK-[0-9]{4}$" },
            "description": "Безопасно параллельно ТОЛЬКО при непересечении областей. По умолчанию пусто."
          },
          "dod": { "type": "array", "items": { "type": "string" }, "minItems": 1, "description": "Критерии готовности." },
          "priority": { "enum": ["P0", "P1", "P2"] },
          "spec_md": { "type": "string", "description": "Тело спеки задачи (markdown, RU)." }
        }
      }
    },
    "waves": {
      "type": "array",
      "description": "Группировка id по волнам: внутри волны параллельно, следующая — после зависимостей.",
      "items": { "type": "array", "items": { "type": "string", "pattern": "^TASK-[0-9]{4}$" } }
    }
  }
}
